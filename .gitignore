# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables and secrets
.env
.env.*
!.env.example

# Project data
data/*.csv
data/*.parquet
data/*.json
data/*.pkl

# Keep the data directory in Git
!data/.gitkeep

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo

# Test and coverage outputs
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checker and linter caches
.mypy_cache/
.pyright/
.ruff_cache/

# Build and packaging files
build/
dist/
*.egg-info/
.eggs/

# Jupyter notebooks
.ipynb_checkpoints/

# IDE settings
.vscode/
.idea/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini
